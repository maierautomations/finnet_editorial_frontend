# n8n-Webhook fuer den Briefing-Intake (nur serverseitig)
N8N_BRIEFING_URL=
# n8n-Webhook fuer den Feed (nur serverseitig)
N8N_FEED_URL=
# Auth-Token fuer beide n8n-Webhooks (Header X-EI-Token, nur serverseitig)
EI_TOKEN=
# 1 = beide API-Routen liefern Mock-Daten aus lib/mock.ts, kein n8n noetig
USE_MOCK=1
# Gemeinsames Redaktions-Passwort fuer das Deployment (Basic Auth via middleware.ts).
# Leer oder nicht gesetzt = kein Schutz (lokal so lassen). ASCII-Zeichen verwenden.
STUDIO_PASSWORT=
